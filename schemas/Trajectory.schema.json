{
  "$defs": {
    "Event": {
      "properties": {
        "index": {
          "minimum": 0,
          "title": "Index",
          "type": "integer"
        },
        "role": {
          "$ref": "#/$defs/EventRole"
        },
        "kind": {
          "$ref": "#/$defs/EventKind"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "timestamp": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Timestamp"
        }
      },
      "required": [
        "index",
        "role",
        "kind",
        "content"
      ],
      "title": "Event",
      "type": "object"
    },
    "EventKind": {
      "enum": [
        "reasoning",
        "command",
        "output",
        "tool_call",
        "system"
      ],
      "title": "EventKind",
      "type": "string"
    },
    "EventRole": {
      "enum": [
        "agent",
        "environment",
        "harness"
      ],
      "title": "EventRole",
      "type": "string"
    },
    "Outcome": {
      "enum": [
        "success",
        "failure",
        "error"
      ],
      "title": "Outcome",
      "type": "string"
    },
    "RunConfig": {
      "description": "Pinned run configuration (constitution \u00a74). Runs without one are exploratory\nand must not enter the dataset.",
      "properties": {
        "harness": {
          "title": "Harness",
          "type": "string"
        },
        "harness_version": {
          "title": "Harness Version",
          "type": "string"
        },
        "run_date": {
          "title": "Run Date",
          "type": "string"
        },
        "extra": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra",
          "type": "object"
        }
      },
      "required": [
        "harness",
        "harness_version",
        "run_date"
      ],
      "title": "RunConfig",
      "type": "object"
    }
  },
  "properties": {
    "trajectory_id": {
      "title": "Trajectory Id",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "task_source": {
      "title": "Task Source",
      "type": "string"
    },
    "agent": {
      "title": "Agent",
      "type": "string"
    },
    "agent_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Version"
    },
    "model": {
      "title": "Model",
      "type": "string"
    },
    "run_config": {
      "$ref": "#/$defs/RunConfig"
    },
    "outcome": {
      "$ref": "#/$defs/Outcome"
    },
    "test_output": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Test Output"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/Event"
      },
      "title": "Events",
      "type": "array"
    },
    "raw_ref": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Ref"
    }
  },
  "required": [
    "trajectory_id",
    "task_id",
    "task_source",
    "agent",
    "model",
    "run_config",
    "outcome",
    "events"
  ],
  "title": "Trajectory",
  "type": "object"
}
